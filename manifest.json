{
  "manifest_version": 3,
  "name": "TikTok Following Cleaner",
  "version": "0.1.0",
  "description": "Varre quem você segue e remove contas abaixo de um mínimo de seguidores.",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs"],
  "host_permissions": ["https://www.tiktok.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TikTok Cleaner",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
