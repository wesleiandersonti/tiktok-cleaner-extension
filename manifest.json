{
  "manifest_version": 3,
  "name": "TikTok Following Analyzer & Cleaner",
  "version": "0.2.0",
  "description": "Analisa contas visiveis em Seguindo e auxilia unfollow manual/assistido com confirmacao.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://www.tiktok.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TikTok Analyzer",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
